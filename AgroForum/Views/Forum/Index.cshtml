@model ForumIndexViewModel

@{
    ViewData["Title"] = "Forum";
}

<section class="forum-shell py-5">
    <div class="container">
        @if (TempData["ForumMessage"] is string message)
        {
            <div class="alert alert-success">@message</div>
        }

        <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
            <div>
                <p class="text-success fw-semibold mb-1">AgroForum</p>
                <h1 class="display-6 fw-bold mb-2">Community discussions</h1>
                <p class="text-muted mb-0">Ask practical questions, share experience, and collect expert input.</p>
            </div>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="btn btn-success" asp-action="Create">Create post</a>
            }
            else
            {
                <a class="btn btn-outline-success" asp-area="Identity" asp-page="/Account/Login">Log in to post</a>
            }
        </div>

        <div class="forum-card mb-4">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-7">
                    <label class="form-label fw-semibold" for="search">Search</label>
                    <input id="search"
                           name="search"
                           value="@Model.Search"
                           class="form-control"
                           placeholder="Search posts or tags" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold" for="tag">Tag</label>
                    <select id="tag" name="tag" class="form-select">
                        <option value="">All tags</option>
                        @foreach (var tag in Model.AvailableTags)
                        {
                            <option value="@tag" selected="@(Model.Tag == tag)">@tag</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-dark">Filter</button>
                </div>
            </form>
        </div>

        @if (Model.Posts.Any())
        {
            <div class="forum-post-list">
                @foreach (var post in Model.Posts)
                {
                    <article class="forum-card forum-post-card">
                        <div class="d-flex flex-wrap justify-content-between gap-3">
                            <div>
                                <div class="d-flex flex-wrap gap-2 mb-2">
                                    @foreach (var tag in post.Tags)
                                    {
                                        <a class="forum-tag text-decoration-none"
                                           asp-action="Index"
                                           asp-route-tag="@tag">@tag</a>
                                    }
                                </div>

                                <h2 class="h4 fw-bold mb-2">
                                    <a class="forum-post-title"
                                       asp-action="Details"
                                       asp-route-id="@post.Id">@post.Title</a>
                                </h2>

                                @if (post.IsPinned)
                                {
                                    <span class="badge text-bg-success me-1">Pinned</span>
                                }
                            </div>

                            @if (post.IsLocked)
                            {
                                <span class="badge text-bg-secondary align-self-start">Locked</span>
                            }
                        </div>

                        <p class="forum-meta mb-2">
                            Posted by @post.AuthorName
                            @if (post.IsAuthorModerator)
                            {
                                <span class="moderator-badge">Moderator</span>
                            }
                            on @post.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")
                        </p>

                        <p class="forum-post-preview text-muted mb-3">@post.Preview</p>

                        <div class="d-flex flex-wrap align-items-center gap-3 forum-meta">
                            <a class="btn btn-success btn-sm"
                               asp-action="Details"
                               asp-route-id="@post.Id">Read full post</a>
                            @if (post.CommentCount > 0)
                            {
                                <a class="btn btn-outline-success btn-sm"
                                   asp-action="Details"
                                   asp-route-id="@post.Id"
                                   asp-fragment="comments">See all comments (@post.CommentCount)</a>
                            }
                            else
                            {
                                <a class="btn btn-outline-success btn-sm"
                                   asp-action="Details"
                                   asp-route-id="@post.Id"
                                   asp-fragment="add-comment">Be the first to comment</a>
                            }
                            <span>@post.FavoriteCount favorites</span>
                            @if (post.IsAnonymous)
                            {
                                <span>Anonymous post</span>
                            }
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="forum-card text-center py-5">
                <h2 class="h4 fw-bold">No discussions found</h2>
                <p class="text-muted mb-0">Start the first discussion or adjust the current filter.</p>
            </div>
        }
    </div>
</section>
