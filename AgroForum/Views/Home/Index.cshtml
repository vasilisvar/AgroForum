@{
    ViewData["Title"] = "Home";
}

<section class="hero-section">
    <div class="container">
        <div class="row align-items-center min-vh-75">
            <div class="col-lg-7 py-5">
                <span class="hero-badge">
                    Agricultural Knowledge Community
                </span>

                <h1 class="display-4 fw-bold mt-3 mb-3">
                    Knowledge grows when
                    <span class="text-success">communities connect.</span>
                </h1>

                <p class="lead text-muted mb-4 hero-description">
                    AgroForum is a discussion platform where farmers can ask
                    questions, share practical experiences, and connect with
                    agricultural experts.
                </p>

                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-success btn-lg px-4"
                       asp-controller="Forum"
                       asp-action="Index">
                        Explore Forum
                    </a>

                    <a class="btn btn-outline-dark btn-lg px-4"
                       asp-area="Identity"
                       asp-page="/Account/Register">
                        Create Account
                    </a>
                </div>
            </div>

            <div class="col-lg-5 py-5">
                <div class="feature-card">
                    <h2 class="h4 fw-bold mb-4">
                        Built for agricultural communities
                    </h2>

                    <div class="feature-item">
                        <div class="feature-icon">01</div>
                        <div>
                            <h3 class="h6 fw-bold mb-1">Ask practical questions</h3>
                            <p class="text-muted mb-0">
                                Share real agricultural challenges with the community.
                            </p>
                        </div>
                    </div>

                    <div class="feature-item">
                        <div class="feature-icon">02</div>
                        <div>
                            <h3 class="h6 fw-bold mb-1">Connect with experts</h3>
                            <p class="text-muted mb-0">
                                Identify contributions from verified agricultural experts.
                            </p>
                        </div>
                    </div>

                    <div class="feature-item">
                        <div class="feature-icon">03</div>
                        <div>
                            <h3 class="h6 fw-bold mb-1">Share knowledge safely</h3>
                            <p class="text-muted mb-0">
                                Participate in a moderated and spam-protected environment.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-white border-top">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <h2 class="h5 fw-bold">Community Discussions</h2>
                <p class="text-muted mb-0">
                    Exchange knowledge through focused agricultural discussions.
                </p>
            </div>

            <div class="col-md-4">
                <h2 class="h5 fw-bold">Verified Expertise</h2>
                <p class="text-muted mb-0">
                    Distinguish expert contributions from general community participation.
                </p>
            </div>

            <div class="col-md-4">
                <h2 class="h5 fw-bold">Content Moderation</h2>
                <p class="text-muted mb-0">
                    Support constructive discussions through reporting and moderation.
                </p>
            </div>
        </div>
    </div>
</section>